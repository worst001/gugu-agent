# Gugu Gateway runtime
GUGU_GATEWAY_HOST=0.0.0.0
GUGU_GATEWAY_PORT=8787
GUGU_GATEWAY_DB_PATH=/var/lib/gugu-gateway/gateway.sqlite

# Business config
GUGU_FREE_CREDITS=50
GUGU_PURCHASE_URL=https://example.com/buy
GUGU_PUBLIC_BASE_URL=https://example.com
GUGU_DASHBOARD_TOKEN_PER_CREDIT=
GUGU_DOWNLOAD_URL=
GUGU_DOWNLOAD_VERSION=
GUGU_DOWNLOAD_SHA256=

# Admin dashboard. Leave empty to disable /admin/dashboard and /admin/api/*.
GUGU_ADMIN_TOKEN=

# Server-side upstream secrets. Do not put these in the desktop app or release artifacts.
GUGU_DEEPSEEK_API_KEY=
GUGU_DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
GUGU_DEEPSEEK_MODEL=deepseek-v4-pro
GUGU_DEEPSEEK_FAST_MODEL=deepseek-v4-flash

GUGU_GLM_API_KEY=
GUGU_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Weighted credit costs
GUGU_MESSAGE_CREDIT_COST=1
GUGU_ATTACHMENT_CREDIT_COST=6
GUGU_FILE_PARSE_CREDIT_COST=3
GUGU_SUMMARIZE_CREDIT_COST=4

# Reserved for official payment integrations. Not used in the manual-payment phase.
GUGU_WECHAT_MCH_ID=
GUGU_WECHAT_APP_ID=
GUGU_WECHAT_API_V3_KEY=
GUGU_WECHAT_PRIVATE_KEY=
GUGU_ALIPAY_APP_ID=
GUGU_ALIPAY_PRIVATE_KEY=
GUGU_ALIPAY_PUBLIC_KEY=

# Desktop build note:
# Set this in the desktop build environment, not on the gateway server process.
# GUGU_DESKTOP_DEFAULT_GATEWAY_URL=https://gateway.example.com
