.env
.env.*
!.env.example
node_modules
.DS_Store

# Local Git worktrees
.worktrees/

# Computer Use runtime (auto-generated)
.runtime/
extracted-natives/

# Adapter attachment cache (created at runtime by AttachmentStore when
# running adapter tests or the feishu/telegram adapters locally)
.lark-attachments/
.tg-attachments/

# Playwright MCP snapshots & logs
.playwright-mcp/

# OMX state/logs
.omx/

# E2E screenshots
e2e-*.png

# Desktop build output
desktop/dist/
desktop/build-artifacts/
desktop/src-tauri/binaries/
desktop/src-tauri/target/
desktop/src-tauri/gen/
desktop/sidecars/.generated/
desktop/package-lock.json

# Desktop brand asset candidates (keep only selected ones in public/)
desktop/brand-assets/

# Claude local config & auto-generated — skills under .claude/skills/ are tracked (CE symlinks + vendor)
.claude/*
!.claude/skills/
!.claude/skills/**

# Only vendor Compound Engineering plugin; keep other third_party trees local-only
.claude/skills/third-party/*
!.claude/skills/third-party/compound-engineering-plugin/
!.claude/skills/third-party/compound-engineering-plugin/**

# Superpowers plans & specs (local only)
docs/superpowers/

# Temp server/web logs
.tmp-*.log
desktop/gugu-dev.*.log

# Debug / temp screenshots (root dir only)
/*.png
bug_attachments/

# Private keys & credentials
*.pem
*.key
*.p12
credentials*.json
*.local.ps1
*.local.sh
secrets/

# TS build cache
*.tsbuildinfo

# Local codegraph index
.codegraph/

# Temp markdown snapshots
sidebar-snapshot.md

# VitePress
docs/.vitepress/dist
docs/.vitepress/cache
runtime/__pycache__

# IDE
.idea
